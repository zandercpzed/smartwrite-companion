{
  "name": "smartwrite-companion",
  "version": "0.8.18",
  "description": "An intelligent writing assistant with real-time statistics, readability analysis, and AI-powered persona feedback.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "vitest",
    "workflow": "node scripts/dev-workflow.mjs",
    "version": "node version-bump.mjs",
    "backup": "bash scripts/daily-backup.sh",
    "release": "npm run build && npm run workflow && node scripts/release.mjs",
    "submit-obsidian": "node scripts/submit-obsidian.mjs",
    "publish": "npm run release && npm run submit-obsidian"
  },
  "keywords": [],
  "author": "Zander Catta Preta",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.24.2",
    "obsidian": "latest",
    "typescript": "^5.7.3",
    "tslib": "^2.6.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "hyphen": "^1.12.0",
    "sbd": "^1.0.19",
    "write-good": "^1.0.8"
  }
}
